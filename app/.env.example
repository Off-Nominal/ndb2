PORT=8000
DATABASE_URL=

DISCORD_CLIENT_API_KEY=

# Web UI: Discord OAuth2 (see docs/frontend/authentication.md). Redirect URI must match the Discord app.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# Web portal: after OAuth, user must be in this guild and have at least one allowed role (Discord REST; bot token).
DISCORD_BOT_TOKEN=
OFFNOMDISCORD_GUILD_ID=
# One or more ROLE_ID_* vars (e.g. ROLE_ID_HOST=...) listing allowed role snowflakes.
ROLE_ID_HOST=

# Optional: re-verify guild + roles on this interval (hours) for existing sessions (default 24). Invalid values fall back to 24.
# WEB_DISCORD_AUTHZ_RECHECK_HOURS=24

# GAME MECHANICS
GM_PREDICTION_UPDATE_WINDOW_HOURS=12

# Optional: Mission Control webhook base URL (omit or leave empty to disable outbound webhooks).
# WEBHOOK_DISCORD_BOT=

# Optional: Express trust proxy (see app/src/server/securityHeaders.ts).
# TRUST_PROXY=

# Optional: Postgres pool size (default 10).
# PG_POOL_MAX=
