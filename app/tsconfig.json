{
  "compilerOptions": {
    "target": "es2020",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["es2021.string"],
    "downlevelIteration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",
    "plugins": [{ "name": "@kitajs/ts-html-plugin" }],
    "baseUrl": ".",
    "paths": {
      "@config": ["src/config.ts"],
      "@shared/*": ["src/shared/*"],
      "@data/*": ["src/data/*"],
      "@domain/*": ["src/domain/*"],
      "@web/*": ["src/web/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.client.ts",
    "src/test/**",
    "src/web/styles/cube-bundle.ts"
  ]
}
