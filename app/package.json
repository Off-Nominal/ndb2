{
  "name": "ndb2-api",
  "version": "2.1.0",
  "description": "Nostradambot 2.0 API",
  "main": "index.js",
  "scripts": {
    "clear": "rm -rf ./dist",
    "transfer-queries": "rm -rf ./dist/data/legacy-queries/sql && mkdir -p ./dist/data/legacy-queries/sql && cp ./src/data/legacy-queries/**/*.sql ./dist/data/legacy-queries/sql/",
    "vendor-htmx": "wireit",
    "build:tokens": "wireit",
    "build:css": "wireit",
    "build:client-js": "wireit",
    "postinstall": "pnpm run build:web-assets",
    "build:web-assets": "wireit",
    "build": "pnpm run build:web-assets && tsc && tsc-alias -p tsconfig.json && pnpm run transfer-queries",
    "compile:dev": "tsc && tsc-alias -p tsconfig.json && pnpm run transfer-queries && pnpm run build:web-assets && node --env-file=.env ./dist/index.js",
    "dev": "pnpm run build:web-assets && pnpm run transfer-queries && NODE_ENV=dev dotenv -- tsx watch src/index.ts",
    "compile": "pnpm run clear && pnpm run build && node --env-file=.env ./dist/index.js",
    "start": "node ./dist/index.js",
    "sql-watch": "dotenv -- pgtyped -w -c pgtyped.config.json",
    "test": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.integration.config.ts",
    "typecheck:client": "tsc -p tsconfig.client.json",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:db": "pnpm run test:integration",
    "test:watch": "vitest --watch --config vitest.unit.config.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@kitajs/html": "^4.2.13",
    "@mendahu/utilities": "^0.9.0",
    "@offnominal/ndb2-db": "workspace:*",
    "@pgtyped/runtime": "^2.4.2",
    "@types/morgan": "^1.9.10",
    "date-fns": "^3.6.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "htmx.org": "^2.0.8",
    "marked": "^18.0.2",
    "node-schedule": "^2.1.1",
    "pg": "^8.12.0",
    "typed-emitter": "^2.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@kitajs/ts-html-plugin": "^4.1.4",
    "@offnominal/ndb2-api-types": "workspace:*",
    "@pgtyped/cli": "^2.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/node-schedule": "^2.1.7",
    "@types/pg": "^8.11.8",
    "@types/supertest": "^6.0.3",
    "chokidar": "^3.6.0",
    "dbmate": "^2.27.0",
    "dotenv-cli": "^8.0.0",
    "morgan": "^1.10.0",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^6.3.5",
    "vitest": "^4.0.8",
    "wireit": "^0.14.12"
  },
  "engines": {
    "node": "22.x"
  },
  "wireit": {
    "vendor-htmx": {
      "command": "mkdir -p ./dist/web/public && cp ./node_modules/htmx.org/dist/htmx.min.js ./dist/web/public/htmx.min.js",
      "files": [
        "./node_modules/htmx.org/dist/htmx.min.js"
      ],
      "output": [
        "dist/web/public/htmx.min.js"
      ]
    },
    "build:tokens": {
      "command": "node ./scripts/build-design-tokens.mjs",
      "files": [
        "scripts/build-design-tokens.mjs",
        "src/web/tokens/**/*.json"
      ],
      "output": [
        "src/web/generated/design-tokens.css"
      ]
    },
    "build:css": {
      "command": "node ./scripts/build-cube-css.mjs",
      "dependencies": [
        "build:tokens"
      ],
      "files": [
        "scripts/build-cube-css.mjs",
        "scripts/generate-cube-blocks-manifest.mjs",
        "src/web/styles/cube-entry.css",
        "src/web/styles/cube-bundle.ts",
        "src/web/styles/**/*.css",
        "src/web/**/*.css"
      ],
      "output": [
        "dist/web/public/cube.css"
      ]
    },
    "build:client-js": {
      "command": "node ./scripts/build-client-js.mjs",
      "dependencies": [
        "vendor-htmx"
      ],
      "files": [
        "scripts/build-client-js.mjs",
        "src/web/routes/**/*.client.ts",
        "src/web/routes/**/*.client.js",
        "src/web/shared/components/**/*.client.ts",
        "src/web/shared/components/**/*.client.js"
      ],
      "output": [
        "dist/web/public/routes/**",
        "src/web/generated/routeClientScripts.ts"
      ]
    },
    "build:web-assets": {
      "command": "mkdir -p ./dist/web/public && cp -R ./src/web/public/. ./dist/web/public/",
      "dependencies": [
        "build:tokens",
        "build:css",
        "build:client-js"
      ],
      "files": [
        "src/web/public/**"
      ],
      "output": [
        "dist/web/public/*.ttf",
        "dist/web/public/.gitkeep"
      ]
    }
  }
}
