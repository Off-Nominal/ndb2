{
  "name": "ndb2-api",
  "version": "2.1.0",
  "description": "Nostradambot 2.0 API",
  "main": "index.js",
  "scripts": {
    "clear": "rm -rf ./dist",
    "transfer-queries": "rm -rf ./dist/data/legacy-queries/sql && mkdir -p ./dist/data/legacy-queries/sql && cp ./src/data/legacy-queries/**/*.sql ./dist/data/legacy-queries/sql/",
    "vendor-htmx": "mkdir -p ./src/web/public && cp ./node_modules/htmx.org/dist/htmx.min.js ./src/web/public/htmx.min.js",
    "build:tokens": "node ./scripts/build-design-tokens.mjs",
    "build:css": "node ./scripts/build-web-css.mjs",
    "build:client-js": "node ./scripts/build-client-js.mjs",
    "postinstall": "pnpm run vendor-htmx && pnpm run build:tokens && pnpm run build:css && pnpm run build:client-js",
    "transfer-web": "mkdir -p ./dist/web/public && cp -R ./src/web/public/. ./dist/web/public/",
    "build": "pnpm run build:tokens && pnpm run build:css && pnpm run build:client-js && tsc && tsc-alias -p tsconfig.json && pnpm run vendor-htmx && pnpm run transfer-queries && pnpm run transfer-web",
    "prepare-dev": "pnpm run build:tokens && pnpm run build:css && pnpm run build:client-js && pnpm run transfer-web",
    "compile:dev": "tsc && tsc-alias -p tsconfig.json && pnpm run transfer-queries && pnpm run transfer-web && node --env-file=.env ./dist/index.js",
    "dev": "pnpm run prepare-dev && concurrently -k -n assets,api \"node ./scripts/dev-watch-assets.mjs\" \"NODE_ENV=dev nodemon\"",
    "compile": "pnpm run clear && pnpm run build && node --env-file=.env ./dist/index.js",
    "start": "node ./dist/index.js",
    "sql-watch": "dotenv -- pgtyped -w -c pgtyped.config.json",
    "test": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:db": "pnpm run test:integration",
    "test:watch": "vitest --watch --config vitest.unit.config.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@kitajs/html": "^4.2.13",
    "@mendahu/utilities": "^0.9.0",
    "@offnominal/ndb2-db": "workspace:*",
    "@pgtyped/runtime": "^2.4.2",
    "@types/morgan": "^1.9.10",
    "date-fns": "^3.6.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "htmx.org": "^2.0.8",
    "node-schedule": "^2.1.1",
    "pg": "^8.12.0",
    "typed-emitter": "^2.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@kitajs/ts-html-plugin": "^4.1.4",
    "@offnominal/ndb2-api-types": "workspace:*",
    "@pgtyped/cli": "^2.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/node-schedule": "^2.1.7",
    "@types/pg": "^8.11.8",
    "@types/supertest": "^6.0.3",
    "chokidar": "^3.6.0",
    "concurrently": "^9.1.0",
    "dbmate": "^2.27.0",
    "dotenv-cli": "^8.0.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.6.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": "22.x"
  }
}
