{
  "name": "ndb2",
  "version": "1.0.0",
  "description": "Nostradambot 2.0 Betting Game for the Off-Nominal Discord",
  "main": "index.js",
  "scripts": {
    "clear": "rm -rf ./dist",
    "build": "tsc",
    "tailwind:css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "scripts": "cp ./dist/scripts/* ./public/scripts",
    "compile": "npm run clear && tsc && npm run tailwind:css && npm run scripts && node --env-file=.env ./dist/index.js",
    "dev": "NODE_ENV=dev nodemon --env-file=.env ./dist/index.js -e ts,tsx --exec \"npm run compile\"",
    "start": "node ./dist/index.js",
    "preview": "node --env-file=.env ./dist/index.js",
    "log": "heroku logs -a ndb2 --tail",
    "log:all": "heroku logs -a ndb2 -n 1500",
    "deploy": "git push heroku main",
    "db:migrate:create": "db-migrate create -m ./db/migrations",
    "db:migrate:up": "db-migrate up -m ./db/migrations",
    "db:migrate:down": "db-migrate down -m ./db/migrations",
    "db:migrate:up-prod": "db-migrate up -m ./db/migrations -e prod",
    "db:reset": "NODE_ENV=dev node ./db/reset.js",
    "db:connect:prod": "heroku pg:psql postgresql-contoured-75136 --app ndb2",
    "db:backup:prod": "heroku pg:backups:capture --app ndb2 && heroku pg:backups:download --app ndb2",
    "db:copy": "pg_restore --verbose --clean --no-acl --no-owner -h localhost -U ndb2_owner -d ndb2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mendahu/ndb2.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mendahu/ndb2/issues"
  },
  "homepage": "https://github.com/mendahu/ndb2#readme",
  "dependencies": {
    "@types/react-dom": "^18.2.19",
    "axios": "^1.6.7",
    "cookie-parser": "^1.4.6",
    "date-fns": "^3.3.1",
    "discord.js": "^14.14.1",
    "express": "^4.18.2",
    "jose": "^5.2.2",
    "node-schedule": "^2.1.1",
    "nodemon": "^3.0.3",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/db-migrate-base": "^0.0.14",
    "@types/db-migrate-pg": "^0.0.13",
    "@types/express": "^4.17.21",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.2.56",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "discord-api-types": "^0.37.70",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x"
  }
}
